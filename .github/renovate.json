{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended",
        "docker:pinDigests",
        "default:automergeDigest"
    ],
    "customManagers": [
        {
            "customType": "regex",
            "managerFilePatterns": [
                "/(^|/)Dockerfile$/"
            ],
            "matchStrings": [
                "# renovate: datasource=(?<datasource>.*?) lookupName=(?<packageName>.*?)(?: versioning=(?<versioning>.*?))?\\s+ARG\\s+(?<depName>.*?)_VERSION=(?<currentValue>.*)\\s"
            ]
        }
    ],
    "packageRules": [
        {
            "matchUpdateTypes": [
                "major"
            ],
            "automerge": false,
            "minimumReleaseAge": "30 days"
        },
        {
            "matchUpdateTypes": [
                "minor",
                "patch",
                "digest"
            ],
            "automerge": false,
            "minimumReleaseAge": "7 days"
        }
    ],
    "lockFileMaintenance": {
        "enabled": false,
        "automerge": true
    }
}
