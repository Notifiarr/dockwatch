{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": ["config:recommended", "docker:pinDigests", "default:automergeDigest"],
    "customManagers": [
      {
        "customType": "regex",
        "fileMatch": ["(^|/)Dockerfile$"],
        "matchStrings": [
          "# renovate: datasource=(?<datasource>.*?) lookupName=(?<lookupName>.*?)(?: versioning=(?<versioning>.*?))?\\s+ARG\\s+(?<depName>.*?)_VERSION=(?<currentValue>.*)\\s"
        ]
      }
    ],
    "packageRules": [
        {
            "matchUpdateTypes": ["major"],
            "automerge": false,
            "minimumReleaseAge": "30 days"
        },
        {
            "matchUpdateTypes": ["minor", "patch", "digest"],
            "automerge": false,
            "minimumReleaseAge": "7 days"
        }
    ],
    "lockFileMaintenance": {
        "enabled": false,
        "automerge": true
    }
}
